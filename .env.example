# ─────────────────────────────────────────────────────────────────────────────
# realtime-subtitle  — example environment file
# Copy to .env and edit as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── ASR ───────────────────────────────────────────────────────────────────────
# Source language (BCP-47 code: vi, en, zh, fr, de, …)
LANGUAGE=vi

# Whisper model size: tiny | base | small | medium | large-v3
# Larger = better quality, slower start, more RAM
MODEL_SIZE=base

# Compute device: cpu | cuda
DEVICE=cpu

# Quantisation: int8 (fastest on CPU) | float16 (GPU) | float32
COMPUTE_TYPE=int8

# ── Realtime transcription ────────────────────────────────────────────────────
REALTIME_MODEL_SIZE=tiny
REALTIME_PROCESSING_PAUSE=0.2

# ── VAD / silence detection ───────────────────────────────────────────────────
SILERO_SENSITIVITY=0.4
WEBRTC_SENSITIVITY=3
POST_SPEECH_SILENCE_DURATION=0.7
MIN_LENGTH_OF_RECORDING=0.5
MIN_GAP_BETWEEN_RECORDINGS=0.01

# ── Speaker attribution ───────────────────────────────────────────────────────
SPEAKER_ENABLED=true
# local (resemblyzer if installed, else heuristic) | noop
SPEAKER_PROVIDER=local
SPEAKER_SIMILARITY_THRESHOLD=0.75

# ── Translation ───────────────────────────────────────────────────────────────
TRANSLATION_ENABLED=true
# argos (argostranslate, fully offline) | noop
TRANSLATION_PROVIDER=argos
TARGET_LANGUAGE=en

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=realtime_subtitle.log

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_MAX_THREADS=4
